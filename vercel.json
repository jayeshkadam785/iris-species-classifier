{
  "builds": [
    {
      "src": "index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/predict",
      "dest": "index.py"
    },
    {
      "src": "/api/health",
      "dest": "index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
